@inherits LayoutComponentBase

<a class="skip-link" href="#main-content">Skip to main content</a>

<div class="layout-shell">
    <aside class="layout-sidebar" aria-label="Studio navigation">
        <div class="sidebar-brand">
            <div class="brand-mark" aria-hidden="true">C</div>
            <div class="brand-copy">
                <span class="brand-eyebrow">Test Studio</span>
                <strong>Cress Studio</strong>
            </div>
        </div>

        <NavMenu />
    </aside>

    <main class="layout-main" id="main-content" tabindex="-1">
        <header class="layout-topbar">
            <span class="topbar-app-name">Cress Studio — Automation workspace</span>
            <div class="layout-topbar-actions">
                <GlobalControlDrawer />
                <ThemeToggle />
            </div>
        </header>

        <section class="layout-body">
            @Body
        </section>

        <StatusBar />
    </main>
</div>

<div id="blazor-error-ui" role="alert">
    <span>Something went wrong while rendering the studio.</span>
    <a href="" class="reload">Reload</a>
    <a class="dismiss" aria-label="Dismiss error">×</a>
</div>
