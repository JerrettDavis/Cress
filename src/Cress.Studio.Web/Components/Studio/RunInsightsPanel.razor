@implements IDisposable
@inject StudioWorkspaceState State

@{
    var recentActivity = FilterRecentActivity(State.RunInsights.RecentActivity).ToList();
    var flakyFlows = FilterFlakyFlows(State.RunInsights.FlakyFlows).ToList();
}

<section class="subpanel">
    <div class="subpanel-header">
        <div>
            <h3>Recent activity</h3>
            <p>Recent runs and workspace changes stay visible without burying the current task.</p>
        </div>
    </div>
    <div class="suite-flow-tools">
        <div class="field-stack suite-flow-search">
            <label for="run-insights-filter">Filter activity and flaky flows</label>
            <div class="explorer-search-field">
                <span class="explorer-search-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                    </svg>
                </span>
                <input id="run-insights-filter"
                       class="text-input explorer-search-input"
                       @bind="_insightsFilter"
                       @bind:event="oninput"
                       placeholder="Find a run, flow, or trend"
                       data-testid="run-insights-filter" />
                @if (!string.IsNullOrWhiteSpace(_insightsFilter))
                {
                    <button type="button" class="explorer-search-clear" aria-label="Clear insights filter" @onclick="ClearFilter">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                        </svg>
                    </button>
                }
            </div>
        </div>
    </div>
    <div class="suite-flow-summary" data-testid="run-insights-summary">
        <span class="pill">@recentActivity.Count activity items</span>
        <span class="pill">@flakyFlows.Count flaky flows</span>
        @if (!string.IsNullOrWhiteSpace(_insightsFilter))
        {
            <span class="pill">Filter: @_insightsFilter</span>
        }
    </div>
    <div class="stack-list">
        @if (recentActivity.Count == 0)
        {
            <p class="subpanel-empty" data-testid="run-insights-activity-empty">No recent activity matches the current filter.</p>
        }
        else
        {
            @foreach (var item in recentActivity)
            {
                <div class="explorer-button insights-activity-item">
                    <strong>@item.Headline</strong>
                    <span>@item.Detail</span>
                </div>
            }
        }
    </div>
</section>

<section class="subpanel">
    <div class="subpanel-header">
        <div>
            <h3>Flake watch</h3>
            <p>Highlight unstable flows so retries and trends are obvious at a glance.</p>
        </div>
    </div>
    @if (flakyFlows.Count == 0)
    {
        <p class="subpanel-empty" data-testid="run-insights-flake-empty">No flaky flows match the current filter.</p>
    }
    else
    {
        <table class="data-table" aria-label="Flake watch">
            <thead>
                <tr>
                    <th scope="col">Flow</th>
                    <th scope="col">Score</th>
                    <th scope="col">Trend</th>
                    <th scope="col">Retries</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in flakyFlows.Take(8))
                {
                    <tr>
                        <td>
                            @if (item.StepBreakdown.Count > 0)
                            {
                                <details class="flake-step-details">
                                    <summary>
                                        <span class="flake-flow-name">@item.Name</span>
                                        <div class="flake-flow-id">@item.FlowId</div>
                                    </summary>
                                    <table class="data-table flake-step-breakdown" aria-label="Step instability for @item.Name">
                                        <thead>
                                            <tr>
                                                <th scope="col">#</th>
                                                <th scope="col">Step</th>
                                                <th scope="col">Fails</th>
                                                <th scope="col">Rate</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var step in item.StepBreakdown)
                                            {
                                                var rateClass = step.FlakeRate >= 50 ? "flake-rate-high"
                                                    : step.FlakeRate > 20 ? "flake-rate-medium"
                                                    : "flake-rate-low";
                                                <tr>
                                                    <td>@(step.StepIndex + 1)</td>
                                                    <td>@step.StepName</td>
                                                    <td>@step.FailCount / @step.TotalCount</td>
                                                    <td class="@rateClass">@step.FlakeRate%</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </details>
                            }
                            else
                            {
                                <span class="flake-flow-name">@item.Name</span>
                                <div class="flake-flow-id">@item.FlowId</div>
                            }
                        </td>
                        <td class="flake-score">@item.FlakeScore</td>
                        <td>@item.Trend</td>
                        <td class="flake-retries">@item.RetryRecoveries</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

<section class="subpanel">
    <div class="subpanel-header">
        <div>
            <h3>Latest comparison</h3>
            <p>Readable diff-style summary for the newest run comparison.</p>
        </div>
    </div>
    <pre class="comparison-narrative">@State.RunInsights.LatestComparison.Summary</pre>
</section>

@code {
    private string _insightsFilter = string.Empty;

    protected override void OnInitialized()
    {
        State.Changed += HandleStateChanged;
    }

    public void Dispose()
    {
        State.Changed -= HandleStateChanged;
    }

    private void HandleStateChanged()
        => InvokeAsync(StateHasChanged);

    private void ClearFilter()
        => _insightsFilter = string.Empty;

    private IEnumerable<StudioRecentActivityItem> FilterRecentActivity(IEnumerable<StudioRecentActivityItem> items)
        => items.Where(item => string.IsNullOrWhiteSpace(_insightsFilter)
            || item.Headline.Contains(_insightsFilter, StringComparison.OrdinalIgnoreCase)
            || item.Detail.Contains(_insightsFilter, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<StudioFlowHealthItem> FilterFlakyFlows(IEnumerable<StudioFlowHealthItem> items)
        => items.Where(item => string.IsNullOrWhiteSpace(_insightsFilter)
            || item.Name.Contains(_insightsFilter, StringComparison.OrdinalIgnoreCase)
            || item.FlowId.Contains(_insightsFilter, StringComparison.OrdinalIgnoreCase)
            || item.Trend.Contains(_insightsFilter, StringComparison.OrdinalIgnoreCase));
}
