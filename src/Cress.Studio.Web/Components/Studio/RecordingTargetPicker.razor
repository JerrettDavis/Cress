@inject StudioWorkspaceState State
@implements IDisposable

@if (State.IsRecorderPickerOpen)
{
    <div class="modal-backdrop" @onclick="Cancel" role="presentation"></div>
    <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="picker-title" data-testid="recording-target-picker">
        <div class="modal-header">
            <h3 id="picker-title">Choose recording target</h3>
            <button type="button" class="action-button" data-testid="recording-picker-close" @onclick="Cancel" aria-label="Close">&#x2715;</button>
        </div>

        @* ── Tab bar ──────────────────────────────────────────────────────── *@
        <div class="picker-tabs" role="tablist" aria-label="Recording mode">
            <button type="button"
                    role="tab"
                    class="picker-tab @(_activeTab == Tab.Desktop ? "picker-tab--active" : string.Empty)"
                    data-testid="recording-picker-tab-desktop"
                    aria-selected="@(_activeTab == Tab.Desktop)"
                    aria-controls="picker-panel-desktop"
                    id="picker-tab-desktop"
                    @onclick="() => SwitchTab(Tab.Desktop)">
                Desktop
            </button>
            <button type="button"
                    role="tab"
                    class="picker-tab @(_activeTab == Tab.Web ? "picker-tab--active" : string.Empty)"
                    data-testid="recording-picker-tab-web"
                    aria-selected="@(_activeTab == Tab.Web)"
                    aria-controls="picker-panel-web"
                    id="picker-tab-web"
                    @onclick="() => SwitchTab(Tab.Web)">
                Web
            </button>
        </div>

        @* ── Desktop panel ───────────────────────────────────────────────── *@
        @if (_activeTab == Tab.Desktop)
        {
            <div id="picker-panel-desktop"
                 role="tabpanel"
                 aria-labelledby="picker-tab-desktop"
                 class="modal-body"
                 data-testid="recording-picker-panel-desktop">
                @if (_loading)
                {
                    <p class="muted">Enumerating running processes...</p>
                }
                else if (_targets.Count == 0)
                {
                    <p class="muted">No windows with visible titles found. Try launching an application first.</p>
                }
                else
                {
                    var filteredTargets = FilterDesktopTargets(_targets).ToList();
                    var attachableCount = filteredTargets.Count(target => target.IsAttachable);

                    <div class="suite-flow-tools">
                        <div class="field-stack suite-flow-search">
                            <label for="desktop-target-filter">Search processes</label>
                            <div class="explorer-search-field">
                                <span class="explorer-search-icon" aria-hidden="true">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                                    </svg>
                                </span>
                                <input id="desktop-target-filter"
                                       class="text-input explorer-search-input"
                                       @bind="_desktopFilter"
                                       @bind:event="oninput"
                                       placeholder="Filter by process, title, or PID"
                                       data-testid="recording-picker-desktop-filter" />
                                @if (!string.IsNullOrWhiteSpace(_desktopFilter))
                                {
                                    <button type="button" class="explorer-search-clear" aria-label="Clear process filter" @onclick="ClearDesktopFilter">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                                        </svg>
                                    </button>
                                }
                            </div>
                        </div>
                        <label class="suite-flow-toggle" for="desktop-attachable-only">
                            <input id="desktop-attachable-only"
                                   type="checkbox"
                                   @bind="_showAttachableOnly"
                                   data-testid="recording-picker-desktop-attachable-only" />
                            <span>Show attachable only</span>
                        </label>
                    </div>

                    <div class="suite-flow-summary" data-testid="recording-picker-desktop-summary">
                        <span class="pill">@filteredTargets.Count shown</span>
                        <span class="pill">@attachableCount attachable</span>
                        @if (_showAttachableOnly)
                        {
                            <span class="pill">Attachable-only filter on</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(_desktopFilter))
                        {
                            <span class="pill">Filter: @_desktopFilter</span>
                        }
                    </div>

                    @if (filteredTargets.Count == 0)
                    {
                        <p class="subpanel-empty" data-testid="recording-picker-desktop-empty-filter">No running processes match the current filters.</p>
                    }
                    else
                    {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th scope="col">Process</th>
                                <th scope="col">Window title</th>
                                <th scope="col">PID</th>
                                <th scope="col"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var target in filteredTargets)
                            {
                                <tr>
                                    <td>@target.ProcessName</td>
                                    <td>@target.MainWindowTitle</td>
                                    <td>@target.ProcessId</td>
                                    <td>
                                        <button type="button"
                                                class="action-button success"
                                                disabled="@(!target.IsAttachable)"
                                                title="@(target.IsAttachable ? "Start recording this process" : "Cannot attach (elevated process)")"
                                                @onclick="() => AttachAsync(target)">
                                            Attach
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    }
                }
            </div>
        }

        @* ── Web panel ───────────────────────────────────────────────────── *@
        @if (_activeTab == Tab.Web)
        {
            <div id="picker-panel-web"
                 role="tabpanel"
                 aria-labelledby="picker-tab-web"
                 class="modal-body"
                 data-testid="recording-picker-panel-web">

                <div class="field-stack">
                    <label for="web-url">URL</label>
                    <input id="web-url"
                            type="url"
                            class="text-input"
                            data-testid="recording-picker-web-url"
                            placeholder="https://example.com"
                           @bind="_webUrl"
                            @bind:event="oninput"
                            autocomplete="url"
                            spellcheck="false" />
                </div>

                <div class="picker-presets" data-testid="recording-picker-web-presets">
                    <span class="field-hint">Quick start</span>
                    <button type="button" class="action-button" data-testid="recording-picker-web-preset-localhost" @onclick="ApplyLocalhostPreset">Localhost</button>
                    <button type="button" class="action-button" data-testid="recording-picker-web-preset-example" @onclick="ApplyExamplePreset">Example site</button>
                </div>

                <div class="field-stack" style="margin-top:0.5rem">
                    <label for="web-browser">Browser</label>
                    <select id="web-browser" class="text-input" @bind="_webBrowser">
                        <option value="chromium">Chromium</option>
                        <option value="firefox">Firefox</option>
                        <option value="webkit">WebKit</option>
                    </select>
                </div>

                <p class="field-hint recording-picker-web-status" data-testid="recording-picker-web-status" aria-live="polite">
                    @GetWebStatusMessage()
                </p>

                <p class="field-hint" style="margin-top:0.5rem">
                    A browser window will open. Navigate and interact normally; events are captured live.
                </p>

                <div style="margin-top:0.75rem">
                    <button type="button"
                            class="action-button success"
                            data-testid="recording-picker-web-start"
                            disabled="@(!IsWebUrlValid())"
                            title="@(IsWebUrlValid() ? "Start recording in browser" : "Enter a valid URL to start")"
                            @onclick="StartWebRecordingAsync">
                        Start recording
                    </button>
                </div>
            </div>
        }

        <div class="modal-footer">
            @if (_activeTab == Tab.Desktop)
            {
                <button type="button" class="action-button" @onclick="RefreshAsync">Refresh</button>
            }
            <button type="button" class="action-button" data-testid="recording-picker-cancel" @onclick="Cancel">Cancel</button>
        </div>
    </div>
}

@code {
    private enum Tab { Desktop, Web }

    private List<RecordingTargetInfo> _targets = [];
    private bool _loading = true;
    private Tab _activeTab = Tab.Desktop;
    private string _desktopFilter = string.Empty;
    private bool _showAttachableOnly;

    // Web tab state
    private string _webUrl = string.Empty;
    private string _webBrowser = "chromium";

    protected override void OnInitialized()
    {
        State.Changed += HandleStateChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (State.IsRecorderPickerOpen && _loading && _activeTab == Tab.Desktop)
        {
            await LoadTargetsAsync();
        }
    }

    public void Dispose()
    {
        State.Changed -= HandleStateChanged;
    }

    private void HandleStateChanged()
        => InvokeAsync(async () =>
        {
            if (State.IsRecorderPickerOpen && _loading && _activeTab == Tab.Desktop)
            {
                await LoadTargetsAsync();
            }

            StateHasChanged();
        });

    private async Task LoadTargetsAsync()
    {
        _loading = true;
        StateHasChanged();
        var list = await State.RecorderService.ListAvailableTargetsAsync();
        _targets = list.ToList();
        _loading = false;
        StateHasChanged();
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        await LoadTargetsAsync();
    }

    private IEnumerable<RecordingTargetInfo> FilterDesktopTargets(IEnumerable<RecordingTargetInfo> targets)
        => targets.Where(DesktopTargetMatchesFilter);

    private bool DesktopTargetMatchesFilter(RecordingTargetInfo target)
    {
        if (_showAttachableOnly && !target.IsAttachable)
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(_desktopFilter))
        {
            return true;
        }

        return target.ProcessName.Contains(_desktopFilter, StringComparison.OrdinalIgnoreCase)
            || target.MainWindowTitle.Contains(_desktopFilter, StringComparison.OrdinalIgnoreCase)
            || target.ProcessId.ToString(System.Globalization.CultureInfo.InvariantCulture).Contains(_desktopFilter, StringComparison.OrdinalIgnoreCase);
    }

    private void ClearDesktopFilter()
        => _desktopFilter = string.Empty;

    private async Task AttachAsync(RecordingTargetInfo target)
    {
        await State.BeginRecordingAsync(target.ProcessId);
        _loading = true; // reset for next open
    }

    private async Task StartWebRecordingAsync()
    {
        if (!IsWebUrlValid()) return;
        await State.BeginWebRecordingAsync(_webUrl.Trim(), _webBrowser);
    }

    private void SwitchTab(Tab tab)
    {
        _activeTab = tab;
        if (tab == Tab.Desktop && _loading)
        {
            // Kick off target loading when switching back to Desktop.
            _ = LoadTargetsAsync();
        }
    }

    private bool IsWebUrlValid()
    {
        var url = _webUrl?.Trim() ?? string.Empty;
        if (string.IsNullOrEmpty(url)) return false;
        return Uri.TryCreate(url, UriKind.Absolute, out var uri)
               && (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);
    }

    private void ApplyWebPreset(string url)
        => _webUrl = url;

    private void ApplyLocalhostPreset()
        => ApplyWebPreset("http://localhost:5000");

    private void ApplyExamplePreset()
        => ApplyWebPreset("https://example.com");

    private string GetWebStatusMessage()
    {
        var url = _webUrl?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(url))
        {
            return "Enter a full http:// or https:// URL, or choose a preset to get started.";
        }

        if (!IsWebUrlValid())
        {
            return "Use a full http:// or https:// URL, for example https://example.com.";
        }

        return $"Recording will open {url} in {GetBrowserLabel(_webBrowser)}.";
    }

    private static string GetBrowserLabel(string browser)
        => browser switch
        {
            "firefox" => "Firefox",
            "webkit" => "WebKit",
            _ => "Chromium"
        };

    private void Cancel()
    {
        State.CloseRecorderPicker();
        _loading = true; // reset so next open re-enumerates
        _activeTab = Tab.Desktop;
        _desktopFilter = string.Empty;
        _showAttachableOnly = false;
        _webUrl = string.Empty;
        _webBrowser = "chromium";
    }
}
