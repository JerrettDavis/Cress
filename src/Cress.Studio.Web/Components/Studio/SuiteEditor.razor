@implements IDisposable
@inject StudioWorkspaceState State

@if (State.SelectedSuite is null)
{
    <div class="empty-panel subpanel-empty">Select or create a suite to edit saved run selections.</div>
}
else
{
    <div class="suite-editor">

        <!-- Identity group -->
        <div class="form-section">
            <h4 class="form-section-heading">Identity</h4>
            <div class="editor-grid two-column">
                <div class="field-stack">
                    <label for="suite-id">Suite id<span class="required-mark" aria-hidden="true">*</span></label>
                    <input id="suite-id" class="text-input" @bind="State.SelectedSuite.Id" />
                </div>
                <div class="field-stack">
                    <label for="suite-name">Suite name<span class="required-mark" aria-hidden="true">*</span></label>
                    <input id="suite-name" class="text-input" @bind="State.SelectedSuite.Name" />
                </div>
            </div>
        </div>

        <!-- Targeting group -->
        <div class="form-section">
            <h4 class="form-section-heading">Targeting</h4>
            <div class="editor-grid two-column">
                <div class="field-stack">
                    <label for="suite-profile">Profile override</label>
                    <input id="suite-profile" class="text-input" list="suiteProfiles" @bind="State.SelectedSuite.Profile" />
                    <small class="form-helper">Leave blank to use the workspace default profile.</small>
                </div>
                <div class="field-stack">
                    <label for="suite-tag">Tag filter</label>
                    <input id="suite-tag" class="text-input" @bind="State.SelectedSuite.Tag" />
                    <small class="form-helper">Comma-separated tags, e.g. <code>auth, smoke</code>.</small>
                </div>
            </div>
            <datalist id="suiteProfiles">
                @foreach (var profile in State.AvailableProfiles)
                {
                    <option value="@profile"></option>
                }
            </datalist>
        </div>

        <!-- Description group -->
        <div class="form-section">
            <h4 class="form-section-heading">Description</h4>
            <div class="field-stack">
                <label for="suite-description">Description</label>
                <textarea id="suite-description" class="text-input multiline-input" @bind="State.SelectedSuite.Description"></textarea>
            </div>
        </div>

        <!-- Reports group -->
        <div class="form-section">
            <h4 class="form-section-heading">Reports &amp; Flows</h4>
            <div class="field-stack">
                <label for="suite-formats">Report formats</label>
                <input id="suite-formats" class="text-input" @bind="State.SelectedSuite.ReportFormatsText" />
                <small class="form-helper">Comma-separated format identifiers, e.g. <code>html, json</code>.</small>
            </div>
            <div class="field-stack">
                <label>Flows in suite</label>
                @{
                    var allFlows = State.AvailableFlows.OrderBy(item => item.Name, StringComparer.OrdinalIgnoreCase).ToList();
                    var selectedCount = allFlows.Count(f => State.SelectedSuite.FlowIds.Contains(f.FlowId));
                }
                <div class="checklist-toolbar">
                    <button type="button" class="checklist-toolbar-link"
                            @onclick="SelectAllFlows">Select all</button>
                    <button type="button" class="checklist-toolbar-link"
                            @onclick="SelectNoFlows">None</button>
                    <span class="checklist-count">@selectedCount / @allFlows.Count selected</span>
                </div>
                <div class="flow-checklist">
                    @foreach (var flow in allFlows)
                    {
                        <label class="check-item" title="@flow.FlowId">
                            <input type="checkbox"
                                   checked="@State.SelectedSuite.FlowIds.Contains(flow.FlowId)"
                                   @onchange="args => ToggleSuiteFlow(flow.FlowId, args.Value)" />
                            <span>
                                <strong title="@flow.Name">@flow.Name</strong>
                                <small>@flow.FlowId</small>
                            </span>
                            @if (!string.IsNullOrWhiteSpace(flow.CapabilityId))
                            {
                                <span class="check-item-badge" title="@flow.CapabilityId">@flow.CapabilityId</span>
                            }
                        </label>
                    }
                </div>
            </div>
        </div>

    </div>
}

@code {
    protected override void OnInitialized()
    {
        State.Changed += HandleStateChanged;
    }

    public void Dispose()
    {
        State.Changed -= HandleStateChanged;
    }

    private void HandleStateChanged()
        => InvokeAsync(StateHasChanged);

    private void ToggleSuiteFlow(string flowId, object? value)
    {
        State.ToggleSuiteFlow(flowId, value as bool? == true);
    }

    private void SelectAllFlows()
    {
        foreach (var flow in State.AvailableFlows)
            State.ToggleSuiteFlow(flow.FlowId, true);
    }

    private void SelectNoFlows()
    {
        foreach (var flow in State.AvailableFlows)
            State.ToggleSuiteFlow(flow.FlowId, false);
    }
}
