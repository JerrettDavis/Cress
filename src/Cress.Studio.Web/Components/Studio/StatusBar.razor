@implements IDisposable
@inject StudioWorkspaceState State

<div class="studio-statusbar" aria-live="polite" aria-label="Studio status" data-testid="status-bar">
    <div class="statusbar-item" aria-label="Current status" data-testid="status-bar-status">
        <span class="statusbar-dot @DotClass" aria-hidden="true"></span>
        <span class="statusbar-badge" data-testid="status-bar-state-label">@StatusLabel</span>
        <span>Status</span>
        <span>: </span>
        <strong title="@State.StatusMessage" data-testid="status-bar-status-text">@State.StatusMessage</strong>
    </div>
    <div class="statusbar-item" aria-label="Live run" data-testid="status-bar-live-run">
        <span>Live</span>
        <span>: </span>
        <span title="@State.LiveRunHeadline" data-testid="status-bar-live-run-text">@State.LiveRunHeadline</span>
    </div>
    <div class="statusbar-item" aria-label="Selection" data-testid="status-bar-selection">
        <span>Selection</span>
        <span>: </span>
        <span title="@State.SelectionHeadline" data-testid="status-bar-selection-text">@State.SelectionHeadline</span>
    </div>
    <div class="statusbar-item" aria-label="Last run" data-testid="status-bar-last-run">
        <span>Last run</span>
        <span>: </span>
        @if (_lastRun is null)
        {
            <span title="@(_lastRunDescription)" data-testid="status-bar-last-run-text">@(_lastRunDescription)</span>
        }
        else
        {
            <span class="statusbar-badge" data-testid="status-bar-last-run-id">@_lastRun.Result.Metadata.RunId</span>
            <span title="@(_lastRunDescription)" data-testid="status-bar-last-run-text">@(_lastRunDescription)</span>
        }
    </div>
</div>

@code {
    private StoredRunResult? _lastRun => State.Runs.FirstOrDefault();
    private string _lastRunDescription => _lastRun is not null ? State.DescribeRun(_lastRun) : "—";

    private string DotClass
    {
        get
        {
            if (State.IsBusy) return "statusbar-dot--running";
            var msg = State.StatusMessage ?? string.Empty;
            if (msg.Contains("error", StringComparison.OrdinalIgnoreCase)
                || msg.Contains("fail", StringComparison.OrdinalIgnoreCase))
                return "statusbar-dot--error";
            if (msg.Contains("pass", StringComparison.OrdinalIgnoreCase)
                || msg.Contains("success", StringComparison.OrdinalIgnoreCase)
                || msg.Contains("complete", StringComparison.OrdinalIgnoreCase))
                return "statusbar-dot--success";
            return "statusbar-dot--idle";
        }
    }

    private string StatusLabel => DotClass switch
    {
        "statusbar-dot--running" => "Running",
        "statusbar-dot--error" => "Issue",
        "statusbar-dot--success" => "Ready",
        _ => "Idle"
    };

    protected override void OnInitialized()
    {
        State.Changed += HandleStateChanged;
    }

    public void Dispose()
    {
        State.Changed -= HandleStateChanged;
    }

    private void HandleStateChanged()
        => InvokeAsync(StateHasChanged);
}
