@inject StudioWorkspaceState State
@implements IDisposable

@if (State.IsWorkspacePickerOpen)
{
    <div class="modal-backdrop" @onclick="Close" role="presentation" data-testid="workspace-picker-backdrop"></div>
    <div class="modal-dialog modal-dialog--wide" role="dialog" aria-modal="true" aria-labelledby="workspace-picker-title" data-testid="workspace-picker-dialog">
        <div class="modal-header">
            <h3 id="workspace-picker-title">Browse for a workspace</h3>
            <button type="button" class="action-button" @onclick="Close" aria-label="Close" data-testid="workspace-picker-close">&#x2715;</button>
        </div>

        <div class="modal-body workspace-picker-body" data-testid="workspace-picker-body">
            <div class="workspace-picker-toolbar" data-testid="workspace-picker-toolbar">
                <div class="field-stack workspace-picker-location">
                    <label for="workspace-picker-location">Current location</label>
                    <input id="workspace-picker-location" class="text-input" value="@State.WorkspaceBrowserLocationLabel" readonly data-testid="workspace-picker-location" />
                </div>

                <div class="workspace-picker-actions">
                    <button type="button" class="action-button" @onclick="BrowseParent" disabled="@string.IsNullOrWhiteSpace(State.WorkspaceBrowserCurrentPath)" data-testid="workspace-picker-up">Up</button>
                    <button type="button" class="action-button" @onclick="BrowseComputer" data-testid="workspace-picker-machine">This machine</button>
                    <button type="button" class="action-button primary" @onclick="SelectCurrentFolder" disabled="@string.IsNullOrWhiteSpace(State.WorkspaceBrowserCurrentPath)" data-testid="workspace-picker-use-current">Use this folder</button>
                    <button type="button" class="action-button success" @onclick="LoadCurrentFolder" disabled="@string.IsNullOrWhiteSpace(State.WorkspaceBrowserCurrentPath)" data-testid="workspace-picker-load-current">Load this folder</button>
                </div>
            </div>

            @{
                var filteredEntries = FilterEntries(State.WorkspaceBrowserEntries).ToList();
                var workspaceMatches = filteredEntries.Count(entry => entry.IsCressWorkspace);
            }

            <div class="field-stack explorer-search-wrap workspace-picker-filter-wrap">
                <label for="workspace-picker-filter">Search folders</label>
                <div class="explorer-search-field">
                    <span class="explorer-search-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                        </svg>
                    </span>
                    <input id="workspace-picker-filter"
                           class="text-input explorer-search-input"
                           @bind="_entryFilter"
                           @bind:event="oninput"
                           placeholder="Filter by folder name or path"
                           data-testid="workspace-picker-filter" />
                    @if (!string.IsNullOrWhiteSpace(_entryFilter))
                    {
                        <button type="button" class="explorer-search-clear" aria-label="Clear workspace filter" @onclick="ClearFilter">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                            </svg>
                        </button>
                    }
                </div>
            </div>

            <div class="suite-flow-summary workspace-picker-summary" data-testid="workspace-picker-summary">
                <span class="pill">@filteredEntries.Count shown</span>
                <span class="pill">@workspaceMatches workspaces</span>
                @if (!string.IsNullOrWhiteSpace(_entryFilter))
                {
                    <span class="pill">Filter: @_entryFilter</span>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(State.WorkspaceBrowserError))
            {
                <div class="workspace-picker-error" data-testid="workspace-picker-error">@State.WorkspaceBrowserError</div>
            }

            @if (State.WorkspaceBrowserEntries.Count == 0)
            {
                <p class="subpanel-empty" data-testid="workspace-picker-empty">No folders are available here. Move up a level or choose another root.</p>
            }
            else if (filteredEntries.Count == 0)
            {
                <p class="subpanel-empty" data-testid="workspace-picker-filter-empty">No folders match the current filter. Clear the search to see the full folder list.</p>
            }
            else
            {
                <div class="workspace-picker-list" data-testid="workspace-picker-list">
                    @foreach (var entry in filteredEntries)
                    {
                        <div class="workspace-picker-row" data-testid="@($"workspace-picker-row-{ToTestIdSegment(entry.Path)}")">
                            <div class="workspace-picker-entry" data-testid="@($"workspace-picker-entry-{ToTestIdSegment(entry.Path)}")">
                                <strong>@entry.Name</strong>
                                <span>@entry.Path</span>
                                <div class="workspace-picker-meta">
                                    @if (!string.IsNullOrWhiteSpace(entry.ItemCountLabel))
                                    {
                                        <span class="pill">@entry.ItemCountLabel</span>
                                    }
                                    @if (entry.IsCressWorkspace)
                                    {
                                        <span class="pill workspace-pill">Cress workspace</span>
                                    }
                                </div>
                            </div>
                            <div class="workspace-picker-row-actions">
                                <button type="button" class="action-button" @onclick="() => Browse(entry.Path)" data-testid="@($"workspace-picker-open-{ToTestIdSegment(entry.Path)}")">Open</button>
                                <button type="button" class="action-button" @onclick="() => Select(entry.Path)" data-testid="@($"workspace-picker-select-{ToTestIdSegment(entry.Path)}")">Select</button>
                                <button type="button" class="action-button success" @onclick="() => Load(entry.Path)" data-testid="@($"workspace-picker-load-{ToTestIdSegment(entry.Path)}")">Load</button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="modal-footer">
            <button type="button" class="action-button" @onclick="Close" data-testid="workspace-picker-cancel">Cancel</button>
        </div>
    </div>
}

@code {
    private string _entryFilter = string.Empty;

    protected override void OnInitialized()
    {
        State.Changed += HandleStateChanged;
    }

    public void Dispose()
    {
        State.Changed -= HandleStateChanged;
    }

    private void HandleStateChanged()
        => InvokeAsync(StateHasChanged);

    private void Close()
    {
        _entryFilter = string.Empty;
        State.CloseWorkspacePicker();
    }

    private void ClearFilter()
        => _entryFilter = string.Empty;

    private void Browse(string path)
        => State.BrowseWorkspacePath(path);

    private void BrowseParent()
        => State.BrowseWorkspaceParent();

    private void BrowseComputer()
        => State.BrowseWorkspacePath(null);

    private void Select(string path)
        => State.ChooseWorkspaceFromPicker(path, loadImmediately: false);

    private void Load(string path)
        => State.ChooseWorkspaceFromPicker(path, loadImmediately: true);

    private void SelectCurrentFolder()
        => State.ChooseWorkspaceFromPicker(State.WorkspaceBrowserCurrentPath, loadImmediately: false);

    private void LoadCurrentFolder()
        => State.ChooseWorkspaceFromPicker(State.WorkspaceBrowserCurrentPath, loadImmediately: true);

    private IEnumerable<StudioDirectoryEntry> FilterEntries(IEnumerable<StudioDirectoryEntry> entries)
        => entries.Where(EntryMatchesFilter);

    private bool EntryMatchesFilter(StudioDirectoryEntry entry)
    {
        if (string.IsNullOrWhiteSpace(_entryFilter))
        {
            return true;
        }

        return entry.Name.Contains(_entryFilter, StringComparison.OrdinalIgnoreCase)
            || entry.Path.Contains(_entryFilter, StringComparison.OrdinalIgnoreCase)
            || (entry.IsCressWorkspace && "workspace".Contains(_entryFilter, StringComparison.OrdinalIgnoreCase));
    }

    private static string ToTestIdSegment(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "empty";
        }

        var builder = new System.Text.StringBuilder(value.Length);
        var lastWasDash = false;
        foreach (var ch in value)
        {
            if (char.IsLetterOrDigit(ch))
            {
                builder.Append(char.ToLowerInvariant(ch));
                lastWasDash = false;
            }
            else if (!lastWasDash)
            {
                builder.Append('-');
                lastWasDash = true;
            }
        }

        return builder.ToString().Trim('-');
    }
}
