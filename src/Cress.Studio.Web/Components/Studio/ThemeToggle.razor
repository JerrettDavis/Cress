@inject IJSRuntime JS

<div class="theme-toggle" role="group" aria-label="Theme selection">
    <button type="button"
            class="@GetButtonClass("system")"
            aria-label="System theme"
            aria-pressed="@(_current == "system" ? "true" : "false")"
            @onclick='() => SetThemeAsync("system")'>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
            <line x1="8" y1="21" x2="16" y2="21"></line>
            <line x1="12" y1="17" x2="12" y2="21"></line>
        </svg>
        <span>System</span>
    </button>
    <button type="button"
            class="@GetButtonClass("light")"
            aria-label="Light theme"
            aria-pressed="@(_current == "light" ? "true" : "false")"
            @onclick='() => SetThemeAsync("light")'>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <span>Light</span>
    </button>
    <button type="button"
            class="@GetButtonClass("dark")"
            aria-label="Dark theme"
            aria-pressed="@(_current == "dark" ? "true" : "false")"
            @onclick='() => SetThemeAsync("dark")'>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
        <span>Dark</span>
    </button>
</div>

@code {
    private string _current = "system";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var stored = await JS.InvokeAsync<string>("getTheme");
                _current = stored ?? "system";
                StateHasChanged();
            }
            catch
            {
                // JS interop not available during pre-rendering — keep default
            }
        }
    }

    private async Task SetThemeAsync(string value)
    {
        _current = value;
        try
        {
            await JS.InvokeVoidAsync("setTheme", value);
        }
        catch
        {
            // JS interop not available during pre-rendering
        }
        StateHasChanged();
    }

    private string GetButtonClass(string value)
        => _current == value ? "tab-button active theme-toggle-btn" : "tab-button theme-toggle-btn";
}
