@implements IDisposable
@inject StudioWorkspaceState State

<aside id="results" class="card results-panel" aria-labelledby="results-title" data-testid="results-panel">
    <div class="panel-header results-panel-header">
        <div class="panel-heading">
            <h2 id="results-title">Runs, evidence, and diagnostics</h2>
            <p>Review live output, artifacts, preview surfaces, and comparisons without leaving the workspace.</p>
        </div>
    </div>

    <section class="subpanel">
        <div class="subpanel-header subpanel-header--sticky">
            <div>
                <h3>Live run</h3>
                <p>Streaming status and event feed for the current execution.</p>
            </div>
        </div>
        <div class="live-headline" data-testid="results-live-headline">@State.LiveRunHeadline</div>
        @if (State.LiveEvents.Count == 0)
        {
            <p class="subpanel-empty" data-testid="results-live-empty">No run in progress — start a run to see live output.</p>
        }
        else
        {
            <ul class="event-list">
                @foreach (var item in State.LiveEvents)
                {
                    <li>@item</li>
                }
            </ul>
        }
    </section>

    <section class="subpanel">
        <div class="subpanel-header subpanel-header--sticky">
            <div>
                <h3>Recent runs</h3>
                <p>Find the right run quickly, then inspect flows, steps, and artifacts below.</p>
            </div>
        </div>
        @{
            var filteredRuns = FilterRuns(State.Runs).ToList();
            var failedRuns = filteredRuns.Count(HasRunFailures);
        }
        <div class="suite-flow-tools">
            <div class="field-stack suite-flow-search">
                <label for="results-run-filter">Search runs</label>
                <div class="explorer-search-field">
                    <span class="explorer-search-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                        </svg>
                    </span>
                    <input id="results-run-filter"
                           class="text-input explorer-search-input"
                           @bind="State.RunFilter"
                           @bind:event="oninput"
                           placeholder="Filter by run id, profile, or status"
                           data-testid="results-run-filter" />
                    @if (!string.IsNullOrWhiteSpace(State.RunFilter))
                    {
                        <button type="button" class="explorer-search-clear" aria-label="Clear run filter" @onclick="ClearRunFilter">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                            </svg>
                        </button>
                    }
                </div>
            </div>
            <label class="suite-flow-toggle" for="results-failed-only">
                <input id="results-failed-only"
                       type="checkbox"
                       @bind="_showFailedRunsOnly"
                       data-testid="results-failed-only" />
                <span>Show failed only</span>
            </label>
        </div>
        <div class="suite-flow-summary results-run-summary" data-testid="results-run-summary">
            <span class="pill">@filteredRuns.Count shown</span>
            <span class="pill">@failedRuns failed</span>
            @if (_showFailedRunsOnly)
            {
                <span class="pill">Failed-only filter on</span>
            }
            @if (!string.IsNullOrWhiteSpace(State.RunFilter))
            {
                <span class="pill">Filter: @State.RunFilter</span>
            }
        </div>
        @if (State.Runs.Count == 0)
        {
            <p class="subpanel-empty" data-testid="results-runs-empty">No runs yet — click Run all to start.</p>
        }
        else if (filteredRuns.Count == 0)
        {
            <p class="subpanel-empty" data-testid="results-runs-filter-empty">No runs match the current filters. Clear the search or disable failed-only to see more runs.</p>
        }
        else
        {
            <div class="stack-list" data-testid="results-runs-list">
                @foreach (var run in filteredRuns)
                {
                    var statusClass = GetRunStatusClass(run);
                    <button type="button" class="@GetExplorerButtonClass(State.SelectedRun?.Result.Metadata.RunId == run.Result.Metadata.RunId)" @onclick="() => State.SelectRun(run)" data-testid="@($"results-run-{ToTestIdSegment(run.Result.Metadata.RunId)}")">
                        <span class="run-status-row">
                            <span class="run-status-dot @statusClass" aria-hidden="true"></span>
                            <strong class="run-id-text">@run.Result.Metadata.RunId</strong>
                        </span>
                        <span class="run-meta-text">@State.DescribeRun(run)</span>
                    </button>
                }
            </div>
        }
    </section>

    <section class="subpanel">
        <div class="subpanel-header subpanel-header--sticky">
            <div>
                <h3>Run flows</h3>
                <p>Outcome-first listing for the selected run.</p>
            </div>
        </div>
        @if (State.SelectedRun is null)
        {
            <p class="subpanel-empty">Select a run above to see its flows.</p>
        }
        else if (!State.SelectedRun.Result.Flows.Any())
        {
            <p class="subpanel-empty">This run has no flow results.</p>
        }
        else
        {
            <div class="stack-list run-flows-list" data-testid="results-flows-list">
                @foreach (var flow in State.SelectedRun.Result.Flows)
                {
                    var flowStatusClass = GetOutcomeStatusClass(flow.Outcome);
                    <button type="button" class="@GetExplorerButtonClass(State.SelectedRunFlow?.FlowId == flow.FlowId)" @onclick="() => State.SelectRunFlow(flow)" data-testid="@($"results-flow-{ToTestIdSegment(flow.FlowId)}")">
                        <span class="run-status-row">
                            <span class="run-status-dot @flowStatusClass" aria-hidden="true"></span>
                            <strong>@flow.Outcome</strong>
                        </span>
                        <span>@flow.Name</span>
                    </button>
                }
            </div>
        }
    </section>

    <section class="subpanel">
        <div class="subpanel-header subpanel-header--sticky">
            <div>
                <h3>Steps</h3>
                <p>Step diagnostics with attempt count and final outcome.</p>
            </div>
        </div>
        @if (State.SelectedRunFlow is null)
        {
            <p class="subpanel-empty">Select a run flow above to see its steps.</p>
        }
        else if (!State.SelectedRunSteps.Any())
        {
            <p class="subpanel-empty">No steps recorded for this flow.</p>
        }
        else
        {
            <div class="stack-list run-steps-list" data-testid="results-steps-list">
                @foreach (var step in State.SelectedRunSteps)
                {
                    var stepStatusClass = GetOutcomeStatusClass(step.Outcome);
                    <button type="button" class="@GetExplorerButtonClass(ReferenceEquals(State.SelectedRunStep, step))" @onclick="() => State.SelectRunStep(step)" data-testid="@($"results-step-{ToTestIdSegment(step.Name)}")">
                        <span class="run-status-row">
                            <span class="run-status-dot @stepStatusClass" aria-hidden="true"></span>
                            <strong>@step.Name</strong>
                        </span>
                        <span class="run-step-meta">@step.Kind • attempt @step.Attempt • @step.Outcome</span>
                    </button>
                }
            </div>
        }
    </section>

    <ArtifactPreviewPanel />

    <section class="subpanel">
        <div class="subpanel-header subpanel-header--sticky">
            <div>
                <h3>Diagnostics</h3>
                <p>Warnings and errors stay readable, scannable, and close to the related workflow surface.</p>
            </div>
        </div>
        @if (!State.Diagnostics.Any())
        {
            <p class="subpanel-empty">No diagnostics — workspace is clean.</p>
        }
        else
        {
            <ul class="diagnostic-list">
                @foreach (var diagnostic in State.Diagnostics)
                {
                    var severityClass = diagnostic.Severity switch
                    {
                        DiagnosticSeverity.Error   => "diagnostic-item--error",
                        DiagnosticSeverity.Warning => "diagnostic-item--warning",
                        _                          => "diagnostic-item--info"
                    };
                    <li class="diagnostic-item @severityClass">
                        <span class="diagnostic-icon" aria-hidden="true">@GetDiagnosticIcon(diagnostic.Severity)</span>
                        <span class="diagnostic-body">
                            <strong>@diagnostic.Severity @diagnostic.Code</strong>
                            <span>@diagnostic.Message</span>
                            @if (!string.IsNullOrWhiteSpace(diagnostic.File))
                            {
                                <small>@diagnostic.File</small>
                            }
                        </span>
                    </li>
                }
            </ul>
        }
    </section>

    <section class="subpanel">
        <div class="subpanel-header subpanel-header--sticky">
            <div>
                <h3>Comparison</h3>
                <p>Readable summary that helps spot regressions or retry improvements quickly.</p>
            </div>
        </div>
        @if (string.IsNullOrWhiteSpace(State.SelectedRunComparison.Summary))
        {
            <p class="subpanel-empty">No comparison available — select a run to generate a diff.</p>
        }
        else
        {
            <pre class="summary-pre">@State.SelectedRunComparison.Summary</pre>
        }
    </section>
</aside>

@code {
    private bool _showFailedRunsOnly;

    protected override void OnInitialized()
    {
        State.Changed += HandleStateChanged;
    }

    public void Dispose()
    {
        State.Changed -= HandleStateChanged;
    }

    private void HandleStateChanged()
        => InvokeAsync(StateHasChanged);

    private void ClearRunFilter()
    {
        State.RunFilter = string.Empty;
    }

    private IEnumerable<StoredRunResult> FilterRuns(IEnumerable<StoredRunResult> runs)
        => runs.Where(RunMatchesFilter);

    private bool RunMatchesFilter(StoredRunResult run)
    {
        if (_showFailedRunsOnly && !HasRunFailures(run))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(State.RunFilter))
        {
            return true;
        }

        return run.Result.Metadata.RunId.Contains(State.RunFilter, StringComparison.OrdinalIgnoreCase)
            || State.DescribeRun(run).Contains(State.RunFilter, StringComparison.OrdinalIgnoreCase)
            || DescribeRunStatus(run).Contains(State.RunFilter, StringComparison.OrdinalIgnoreCase);
    }

    private static bool HasRunFailures(StoredRunResult run)
        => !run.Result.Passed
           || run.Result.Flows.Any(flow => flow.Outcome is RunOutcome.Failed or RunOutcome.Errored or RunOutcome.Blocked);

    private static string GetRunStatusClass(StoredRunResult run)
        => HasRunFailures(run) ? "run-status--failed"
            : run.Result.Flows.Any(flow => flow.Outcome == RunOutcome.Skipped) ? "run-status--partial"
            : "run-status--passed";

    private static string GetOutcomeStatusClass(RunOutcome outcome)
        => outcome switch
        {
            RunOutcome.Passed => "run-status--passed",
            RunOutcome.Skipped => "run-status--partial",
            _ => "run-status--failed"
        };

    private static string DescribeRunStatus(StoredRunResult run)
        => GetRunStatusClass(run) switch
        {
            "run-status--passed" => "passed success green",
            "run-status--partial" => "partial skipped warning amber",
            _ => "failed errored blocked danger red"
        };

    private static string GetExplorerButtonClass(bool selected)
        => selected ? "explorer-button selected" : "explorer-button";

    private static string GetDiagnosticIcon(DiagnosticSeverity severity)
        => severity switch
        {
            DiagnosticSeverity.Error   => "✕",
            DiagnosticSeverity.Warning => "⚠",
            _                          => "ℹ"
        };

    private static string ToTestIdSegment(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "empty";
        }

        var builder = new System.Text.StringBuilder(value.Length);
        var lastWasDash = false;
        foreach (var ch in value)
        {
            if (char.IsLetterOrDigit(ch))
            {
                builder.Append(char.ToLowerInvariant(ch));
                lastWasDash = false;
            }
            else if (!lastWasDash)
            {
                builder.Append('-');
                lastWasDash = true;
            }
        }

        return builder.ToString().Trim('-');
    }
}
