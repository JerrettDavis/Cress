@implements IDisposable
@inject StudioWorkspaceState State

<section class="subpanel live-run-panel" aria-labelledby="@TitleId" data-testid="live-run-panel">
    <div class="subpanel-header">
        <div>
            <h3 id="@TitleId">Live run monitor</h3>
            <p>Track the active flow, current step, and timeline while execution is in flight.</p>
        </div>
        <div class="live-run-panel-actions">
            @if (!Compact)
            {
                <button type="button"
                        class="action-button"
                        @onclick="State.ToggleLiveLogVisibility"
                        data-testid="toggle-live-log">
                    @(State.IsLiveLogVisible ? "Hide live log" : "Show live log")
                </button>
            }
            <button type="button"
                    class="action-button danger"
                    @onclick="State.StopActiveRun"
                    disabled="@(!State.CanStopRun)"
                    data-testid="stop-live-run">
                Stop run
            </button>
        </div>
    </div>

    <div class="live-run-summary">
        <div class="summary-card">
            <span>Status</span>
            <strong data-testid="live-run-status">@State.LiveRunStatus</strong>
            <div class="muted">@State.LiveRunHeadline</div>
        </div>
        <div class="summary-card">
            <span>Flow</span>
            <strong data-testid="live-run-flow">@State.LiveCurrentFlow</strong>
            <div class="muted">
                @if (State.LiveTotalFlows > 0)
                {
                    <text>Flow @Math.Max(State.LiveCurrentFlowIndex, State.LiveCompletedFlows + (State.IsBusy ? 1 : 0)) / @State.LiveTotalFlows</text>
                }
                else
                {
                    <text>No flow selected</text>
                }
            </div>
        </div>
        <div class="summary-card">
            <span>Step</span>
            <strong data-testid="live-run-step">@State.LiveCurrentStep</strong>
            <div class="muted">@BuildStepLabel()</div>
        </div>
        <div class="summary-card">
            <span>Elapsed</span>
            <strong data-testid="live-run-elapsed">@FormatElapsed(State.LiveStepElapsed)</strong>
            <div class="muted">@State.LiveCurrentStepMessage</div>
        </div>
    </div>

    <div class="live-run-badges">
        <span class="@GetBadgeClass(State.LiveRunStatus)" data-testid="live-run-status-badge">@State.LiveRunStatus</span>
        <span class="live-run-chip">@GetNodeLabel()</span>
        @if (State.LiveTotalFlows > 0)
        {
            <span class="live-run-chip">Flow @BuildFlowCounter()</span>
        }
        @if (State.LiveTotalSteps > 0)
        {
            <span class="live-run-chip">Overall @State.LiveCompletedSteps / @State.LiveTotalSteps steps</span>
        }
    </div>

    <section class="live-run-current" data-testid="live-run-current">
        <div class="live-run-current-copy">
            <span class="live-run-section-kicker">Current checkpoint</span>
            <strong data-testid="live-run-current-title">@BuildCurrentCheckpointTitle()</strong>
            <p data-testid="live-run-current-message">@State.LiveCurrentStepMessage</p>
        </div>
        <div class="live-run-current-meta">
            <span>@BuildFlowProgressSummary()</span>
            <span>@BuildStepProgressSummary()</span>
            <span>@BuildElapsedSummary()</span>
        </div>
    </section>

    <div class="live-run-progress-grid">
        <div class="field-stack">
            <label>Run progress</label>
            <progress max="@(Math.Max(1, State.LiveTotalFlows))" value="@Math.Min(State.LiveCompletedFlows, Math.Max(1, State.LiveTotalFlows))" data-testid="live-run-flow-progress"></progress>
            <span class="field-hint">@State.LiveCompletedFlows / @State.LiveTotalFlows flows completed</span>
        </div>
        <div class="field-stack">
            <label>Step progress</label>
            <progress max="@(Math.Max(1, State.LiveTotalSteps))" value="@Math.Min(State.LiveCompletedSteps, Math.Max(1, State.LiveTotalSteps))" data-testid="live-run-step-progress"></progress>
            <span class="field-hint">@State.LiveCompletedSteps / @State.LiveTotalSteps steps completed</span>
        </div>
    </div>

    @if (!Compact && State.IsLiveLogVisible)
    {
        <div class="field-stack">
            <label>Timeline and live log</label>
            @if (!State.HasLiveTimeline)
            {
                <div class="subpanel-empty" data-testid="live-run-log-empty">No live events yet.</div>
            }
            else
            {
                <ol class="live-run-log live-run-timeline" data-testid="live-run-log">
                    @foreach (var entry in State.LiveTimelineEntries.Take(24))
                    {
                        <li class="live-run-timeline-item @GetTimelineItemClass(entry)">
                            <div class="live-run-timeline-meta">
                                <span class="live-run-timeline-badge">@entry.Category</span>
                                @if (!string.IsNullOrWhiteSpace(entry.FlowName))
                                {
                                    <span class="live-run-timeline-scope">@entry.FlowName</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(entry.StepName))
                                {
                                    <span class="live-run-timeline-scope">@entry.StepName</span>
                                }
                                <span class="live-run-timeline-time">@FormatTimestamp(entry.TimestampUtc)</span>
                            </div>
                            <strong>@entry.Headline</strong>
                            @if (!string.IsNullOrWhiteSpace(entry.Detail))
                            {
                                <div class="muted">@entry.Detail</div>
                            }
                        </li>
                    }
                </ol>
            }
        </div>
    }
</section>

@code {
    [Parameter]
    public bool Compact { get; set; }

    private string TitleId => Compact ? "designer-live-run-title" : "workspace-live-run-title";

    protected override void OnInitialized()
    {
        State.Changed += HandleStateChanged;
    }

    public void Dispose()
    {
        State.Changed -= HandleStateChanged;
    }

    private void HandleStateChanged()
        => InvokeAsync(StateHasChanged);

    private string BuildStepLabel()
    {
        if (State.LiveCurrentFlowStepCount <= 0)
        {
            return State.LiveCurrentStepMessage;
        }

        return $"Step {Math.Max(State.LiveCurrentFlowStepIndex, 0)} / {State.LiveCurrentFlowStepCount}";
    }

    private string BuildCurrentCheckpointTitle()
        => string.Equals(State.LiveCurrentStep, "—", StringComparison.Ordinal)
            ? State.LiveCurrentFlow
            : $"{State.LiveCurrentFlow} -> {State.LiveCurrentStep}";

    private string BuildFlowCounter()
        => $"{Math.Max(State.LiveCurrentFlowIndex, State.LiveCompletedFlows + (State.IsBusy ? 1 : 0))} / {State.LiveTotalFlows}";

    private string BuildFlowProgressSummary()
        => State.LiveTotalFlows > 0
            ? $"{State.LiveCompletedFlows} of {State.LiveTotalFlows} flows complete"
            : "Waiting for the run plan.";

    private string BuildStepProgressSummary()
        => State.LiveTotalSteps > 0
            ? $"{State.LiveCompletedSteps} of {State.LiveTotalSteps} steps complete"
            : "Waiting for the first runnable step.";

    private string BuildElapsedSummary()
        => State.LiveStepStartedAt is null
            ? "No step timer active"
            : $"Elapsed {FormatElapsed(State.LiveStepElapsed)}";

    private string GetNodeLabel()
        => $"Node: {(State.SelectedRunnerNode?.DisplayName ?? "local embedded node")}";

    private static string GetTimelineItemClass(StudioLiveRunEntry entry)
        => entry.Status.ToLowerInvariant() switch
        {
            "passed" => "live-run-timeline-item--passed",
            "failed" => "live-run-timeline-item--failed",
            "error" => "live-run-timeline-item--failed",
            "warning" => "live-run-timeline-item--warning",
            "stopping" => "live-run-timeline-item--warning",
            _ => string.Empty
        };

    private static string GetBadgeClass(string status)
        => $"live-run-chip live-run-chip--{status.ToLowerInvariant().Replace(' ', '-')}";

    private static string FormatTimestamp(DateTimeOffset timestamp)
        => timestamp.ToLocalTime().ToString("HH:mm:ss");

    private static string FormatElapsed(TimeSpan elapsed)
        => elapsed <= TimeSpan.Zero
            ? "—"
            : elapsed.TotalHours >= 1
                ? elapsed.ToString(@"hh\:mm\:ss")
                : elapsed.ToString(@"mm\:ss");
}
