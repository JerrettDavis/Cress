@implements IDisposable
@inject StudioWorkspaceState State

<aside class="card explorer-panel" aria-labelledby="explorer-title" data-testid="explorer-panel">
    <div class="panel-header">
        <div class="panel-heading">
            <span class="panel-kicker">Workspace</span>
            <h2 id="explorer-title">Explorer</h2>
            <p>Browse the current workspace by flow, suite, capability, fixture, step, or run.</p>
        </div>
        @if (State.HasLoadedProject)
        {
            <span class="pill">@State.FlowCount flows</span>
        }
    </div>

    @if (!State.HasLoadedProject)
    {
        <div class="empty-panel" data-testid="explorer-empty">Load a Cress workspace to browse flows, suites, steps, fixtures, capabilities, runs, and reports.</div>
    }
    else
    {
        var filterActive = !string.IsNullOrWhiteSpace(State.ExplorerFilter);
        var flows = State.Snapshot!.Catalog.NormalizedFlows
            .Where(item => string.IsNullOrWhiteSpace(State.ExplorerFilter)
                || item.Name.Contains(State.ExplorerFilter, StringComparison.OrdinalIgnoreCase)
                || item.FlowId.Contains(State.ExplorerFilter, StringComparison.OrdinalIgnoreCase))
            .OrderBy(item => item.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
        var suites = State.Suites
            .Where(item => string.IsNullOrWhiteSpace(State.ExplorerFilter)
                || item.Name.Contains(State.ExplorerFilter, StringComparison.OrdinalIgnoreCase)
                || item.Id.Contains(State.ExplorerFilter, StringComparison.OrdinalIgnoreCase))
            .OrderBy(item => item.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
        var capabilities = State.Snapshot!.Catalog.Capabilities
            .Where(item => string.IsNullOrWhiteSpace(State.ExplorerFilter)
                || item.Name.Contains(State.ExplorerFilter, StringComparison.OrdinalIgnoreCase)
                || item.Id.Contains(State.ExplorerFilter, StringComparison.OrdinalIgnoreCase))
            .OrderBy(item => item.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
        var fixtures = State.Snapshot!.Catalog.FixtureDefinitions
            .Where(item => string.IsNullOrWhiteSpace(State.ExplorerFilter)
                || item.Key.Contains(State.ExplorerFilter, StringComparison.OrdinalIgnoreCase)
                || item.Value.Type.Contains(State.ExplorerFilter, StringComparison.OrdinalIgnoreCase))
            .OrderBy(item => item.Key, StringComparer.OrdinalIgnoreCase)
            .ToList();
        var steps = State.Snapshot!.Catalog.StepRegistry.Definitions.Values
            .Where(item => string.IsNullOrWhiteSpace(State.ExplorerFilter)
                || item.Name.Contains(State.ExplorerFilter, StringComparison.OrdinalIgnoreCase))
            .OrderBy(item => item.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
        var runs = State.Runs
            .Where(run => string.IsNullOrWhiteSpace(State.ExplorerFilter)
                || run.Result.Metadata.RunId.Contains(State.ExplorerFilter, StringComparison.OrdinalIgnoreCase)
                || State.DescribeRun(run).Contains(State.ExplorerFilter, StringComparison.OrdinalIgnoreCase))
            .ToList();
        var totalMatches = flows.Count + suites.Count + capabilities.Count + fixtures.Count + steps.Count + runs.Count;
        <div class="field-stack explorer-search-wrap">
            <label for="explorerFilter" class="visually-hidden">Search explorer</label>
            <div class="explorer-search-field">
                <span class="explorer-search-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                    </svg>
                </span>
                <input id="explorerFilter" class="text-input explorer-search-input" @bind="State.ExplorerFilter" @bind:event="oninput" placeholder="Find a flow, suite, or capability" data-testid="explorer-filter" />
                @if (!string.IsNullOrEmpty(State.ExplorerFilter))
                {
                    <button type="button" class="explorer-search-clear" aria-label="Clear filter" @onclick="ClearFilter">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                        </svg>
                    </button>
                }
            </div>
        </div>
        @if (filterActive)
        {
            <div class="suite-flow-summary explorer-filter-summary" data-testid="explorer-filter-summary">
                <span class="pill">@totalMatches matches</span>
                <span class="pill">@flows.Count flows</span>
                <span class="pill">@suites.Count suites</span>
                <span class="pill">@capabilities.Count capabilities</span>
                <span class="pill">@fixtures.Count fixtures</span>
                <span class="pill">@steps.Count steps</span>
                <span class="pill">@runs.Count runs</span>
            </div>
            @if (totalMatches == 0)
            {
                <div class="subpanel-empty explorer-filter-empty" data-testid="explorer-filter-empty">No explorer items match the current filter. Clear the search to restore the full workspace tree.</div>
            }
        }

        <details open="@ShouldSectionBeOpen(true, flows.Count, filterActive)" data-testid="explorer-flows-section">
            <summary>
                <span class="summary-chevron" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </span>
                Flows <span class="summary-count">(@State.FlowCount)</span>
            </summary>
            <div class="explorer-group" data-testid="explorer-flows">
                @if (flows.Count == 0)
                {
                    <p class="explorer-empty">No flows match the filter.</p>
                }
                else
                {
                    @foreach (var flow in flows)
                    {
                        <button type="button" class="@GetExplorerButtonClass(State.SelectedFlow?.FilePath == flow.SourceFile)" @onclick="() => SelectFlow(flow.SourceFile)" data-testid="@($"explorer-flow-{ToTestIdSegment(flow.FlowId)}")">
                            <strong>@flow.Name</strong>
                            <span>@flow.FlowId</span>
                        </button>
                    }
                }
            </div>
        </details>

        <details open="@ShouldSectionBeOpen(true, suites.Count, filterActive)" data-testid="explorer-suites-section">
            <summary>
                <span class="summary-chevron" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </span>
                Suites <span class="summary-count">(@State.Suites.Count)</span>
            </summary>
            <div class="explorer-group" data-testid="explorer-suites">
                @if (suites.Count == 0 && State.Suites.Count == 0)
                {
                    <p class="explorer-empty">No suites defined.</p>
                }
                else if (suites.Count == 0)
                {
                    <p class="explorer-empty">No suites match the filter.</p>
                }
                else
                {
                    @foreach (var suite in suites)
                    {
                        <button type="button" class="@GetExplorerButtonClass(State.SelectedSuite?.FilePath == suite.FilePath)" @onclick="() => SelectSuite(suite)" data-testid="@($"explorer-suite-{ToTestIdSegment(suite.Id)}")">
                            <strong>@suite.Name</strong>
                            <span>@suite.Id</span>
                        </button>
                    }
                }
            </div>
        </details>

        <details open="@ShouldSectionBeOpen(false, capabilities.Count, filterActive)" data-testid="explorer-capabilities-section">
            <summary>
                <span class="summary-chevron" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </span>
                Capabilities <span class="summary-count">(@State.CapabilityCount)</span>
            </summary>
            <div class="explorer-group" data-testid="explorer-capabilities">
                @if (capabilities.Count == 0)
                {
                    <p class="explorer-empty">No capabilities@(State.CapabilityCount == 0 ? " defined." : " match the filter.")</p>
                }
                else
                {
                    @foreach (var capability in capabilities)
                    {
                        <button type="button" class="explorer-button" @onclick="() => SelectCapability(capability)">
                            <strong>@capability.Name</strong>
                            <span>@capability.Id</span>
                        </button>
                    }
                }
            </div>
        </details>

        <details open="@ShouldSectionBeOpen(false, fixtures.Count, filterActive)" data-testid="explorer-fixtures-section">
            <summary>
                <span class="summary-chevron" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </span>
                Fixtures <span class="summary-count">(@State.FixtureCount)</span>
            </summary>
            <div class="explorer-group" data-testid="explorer-fixtures">
                @if (fixtures.Count == 0)
                {
                    <p class="explorer-empty">No fixtures@(State.FixtureCount == 0 ? " defined." : " match the filter.")</p>
                }
                else
                {
                    @foreach (var fixture in fixtures)
                    {
                        <button type="button" class="explorer-button" @onclick="() => SelectFixture(fixture.Key)">
                            <strong>@fixture.Key</strong>
                            <span>@fixture.Value.Type</span>
                        </button>
                    }
                }
            </div>
        </details>

        <details open="@ShouldSectionBeOpen(false, steps.Count, filterActive)" data-testid="explorer-steps-section">
            <summary>
                <span class="summary-chevron" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </span>
                Steps <span class="summary-count">(@State.StepCount)</span>
            </summary>
            <div class="explorer-group" data-testid="explorer-steps">
                @if (steps.Count == 0)
                {
                    <p class="explorer-empty">No steps@(State.StepCount == 0 ? " defined." : " match the filter.")</p>
                }
                else
                {
                    @foreach (var step in steps)
                    {
                        <button type="button" class="explorer-button" @onclick="() => SelectStep(step.Name)">
                            <strong>@step.Name</strong>
                            <span>@(step.Implementation?.Plugin ?? "builtin")/@(step.Implementation?.Operation ?? "n/a")</span>
                        </button>
                    }
                }
            </div>
        </details>

        <details open="@ShouldSectionBeOpen(false, runs.Count, filterActive)" data-testid="explorer-runs-section">
            <summary>
                <span class="summary-chevron" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </span>
                Runs <span class="summary-count">(@State.Runs.Count)</span>
            </summary>
            <div class="explorer-group" data-testid="explorer-runs">
                @if (runs.Count == 0)
                {
                    <p class="explorer-empty">No runs yet — click Run all to start.</p>
                }
                else
                {
                    @foreach (var run in runs)
                    {
                        <button type="button" class="@GetExplorerButtonClass(State.SelectedRun?.Result.Metadata.RunId == run.Result.Metadata.RunId)" @onclick="() => SelectRun(run)">
                            <strong>@run.Result.Metadata.RunId</strong>
                            <span>@State.DescribeRun(run)</span>
                        </button>
                    }
                }
            </div>
        </details>
    }
</aside>

@code {
    protected override void OnInitialized()
    {
        State.Changed += HandleStateChanged;
    }

    public void Dispose()
    {
        State.Changed -= HandleStateChanged;
    }

    private void HandleStateChanged()
        => InvokeAsync(StateHasChanged);

    private void ClearFilter()
    {
        State.ExplorerFilter = string.Empty;
    }

    private static bool ShouldSectionBeOpen(bool defaultOpen, int matchCount, bool filterActive)
        => defaultOpen || (filterActive && matchCount > 0);

    private static string ToTestIdSegment(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "empty";
        }

        var builder = new System.Text.StringBuilder(value.Length);
        var lastWasDash = false;
        foreach (var ch in value)
        {
            if (char.IsLetterOrDigit(ch))
            {
                builder.Append(char.ToLowerInvariant(ch));
                lastWasDash = false;
            }
            else if (!lastWasDash)
            {
                builder.Append('-');
                lastWasDash = true;
            }
        }

        return builder.ToString().Trim('-');
    }

    private void SelectFlow(string? path)
        => State.SelectFlow(path);

    private void SelectSuite(StudioSuiteDocument suite)
        => State.SelectSuite(suite);

    private void SelectCapability(CressCapability capability)
        => State.SelectCapability(capability);

    private void SelectFixture(string fixtureName)
        => State.SelectFixture(fixtureName);

    private void SelectStep(string stepName)
        => State.SelectStep(stepName);

    private void SelectRun(StoredRunResult run)
        => State.SelectRun(run);

    private static string GetExplorerButtonClass(bool selected)
        => selected ? "explorer-button selected" : "explorer-button";
}
