<Window x:Class="Cress.Studio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:viewModels="clr-namespace:Cress.Studio.ViewModels"
        xmlns:converters="clr-namespace:Cress.Studio.Converters"
        mc:Ignorable="d"
        Title="Cress Studio"
        Width="1680"
        Height="960"
        MinWidth="1280"
        MinHeight="720"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource StudioWindowBackgroundBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="6"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <converters:WindowStateToMarginConverter x:Key="WindowStateToMarginConverter" />

        <DataTemplate DataType="{x:Type viewModels:ExplorerNodeViewModel}">
            <TextBlock Text="{Binding DisplayName}" />
        </DataTemplate>

        <!-- Window control button base style -->
        <Style x:Key="ChromeButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource StudioWindowControlForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource StudioWindowControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button: red hover -->
        <Style x:Key="ChromeCloseButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ChromeButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource StudioWindowControlCloseHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource StudioWindowControlCloseHoverForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Root grid: compensates for maximize overflow -->
    <Grid x:Name="RootGrid"
          Margin="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource WindowStateToMarginConverter}}">
        <Grid.RowDefinitions>
            <!-- Custom title bar -->
            <RowDefinition Height="40" />
            <!-- App content -->
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  Custom title bar                                               -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource StudioTitleBarBrush}"
                BorderBrush="{DynamicResource StudioBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Icon + title -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Drag area (fills remaining space) -->
                    <ColumnDefinition Width="*" />
                    <!-- Window controls -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- App icon + title text — not hit-test visible so the bar drags -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False">
                    <!-- Geometric glyph — Segoe MDL2 "Code" icon -->
                    <TextBlock Text="&#xE943;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Foreground="{DynamicResource StudioAccentBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Text="Cress Studio"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource StudioTitleBarForegroundBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Invisible drag area -->
                <Rectangle Grid.Column="1"
                           Fill="Transparent"
                           IsHitTestVisible="False" />

                <!-- Window control buttons — must be hit-test visible in chrome -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Stretch">
                    <!-- Minimize -->
                    <Button Style="{StaticResource ChromeButtonStyle}"
                            ToolTip="Minimize"
                            Click="MinimizeButton_Click">
                        <!-- U+E921 Chrome Minimize in Segoe MDL2 -->
                        <TextBlock Text="&#xE921;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   VerticalAlignment="Center" />
                    </Button>
                    <!-- Maximize / Restore -->
                    <Button Style="{StaticResource ChromeButtonStyle}"
                            ToolTip="Maximize"
                            Click="MaximizeRestoreButton_Click">
                        <!-- U+E922 Chrome Maximize, U+E923 Chrome Restore -->
                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="10">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Text" Value="&#xE922;" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                            <Setter Property="Text" Value="&#xE923;" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <!-- Close -->
                    <Button Style="{StaticResource ChromeCloseButtonStyle}"
                            ToolTip="Close"
                            Click="CloseButton_Click">
                        <!-- U+E8BB Chrome Close -->
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   VerticalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  Header panel (was Grid.Row="0", now Row="1")                  -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Margin="20,20,20,12"
                Padding="20"
                CornerRadius="24"
                Background="{DynamicResource StudioSurfaceBrush}"
                BorderBrush="{DynamicResource StudioBorderBrush}"
                BorderThickness="1">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource StudioEyebrowText}" Text="Automation studio" />
                        <TextBlock Style="{StaticResource StudioTitleText}" Margin="0,6,0,0" Text="Cress Studio" />
                        <TextBlock Margin="0,8,0,0"
                                   MaxWidth="720"
                                   Style="{StaticResource StudioMutedText}"
                                   Text="Design flows, validate suites, inspect evidence, and triage failures in a system-theme-aware workspace built for high-clarity test automation work." />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Border Style="{StaticResource StudioStatusPill}">
                            <TextBlock Style="{StaticResource StudioBadgeText}" Text="System theme aware" />
                        </Border>
                        <Border Style="{StaticResource StudioStatusPill}">
                            <TextBlock Style="{StaticResource StudioBadgeText}" Text="Keyboard-first" />
                        </Border>
                        <Border Style="{StaticResource StudioStatusPill}">
                            <TextBlock Style="{StaticResource StudioBadgeText}" Text="Evidence-ready" />
                        </Border>
                    </WrapPanel>
                </Grid>

                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource StudioPanelCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource StudioSectionTitleText}" Text="Primary actions" />
                            <TextBlock Margin="0,6,0,14"
                                       Style="{StaticResource StudioMutedText}"
                                       Text="Open a workspace, round-trip source edits, apply quick fixes, and run exactly the scope you need." />
                            <WrapPanel>
                                <Button Style="{StaticResource PrimaryActionButton}"
                                        AutomationProperties.AutomationId="OpenProjectButton"
                                        Command="{Binding OpenProjectCommand}"
                                        Content="Open project" />
                                <Button AutomationProperties.AutomationId="RefreshProjectButton"
                                        Command="{Binding RefreshProjectCommand}"
                                        Content="Refresh" />
                                <Button AutomationProperties.AutomationId="NewFlowButton"
                                        Command="{Binding NewFlowCommand}"
                                        Content="New flow" />
                                <Button Style="{StaticResource PrimaryActionButton}"
                                        AutomationProperties.AutomationId="SaveFlowButton"
                                        Command="{Binding SaveFlowCommand}"
                                        Content="Save flow" />
                                <Button AutomationProperties.AutomationId="ApplySourceButton"
                                        Command="{Binding ApplySourceCommand}"
                                        Content="Apply source" />
                                <Button AutomationProperties.AutomationId="RebuildSourceButton"
                                        Command="{Binding RebuildSourceCommand}"
                                        Content="Rebuild source" />
                                <Button AutomationProperties.AutomationId="ApplyQuickActionButton"
                                        Command="{Binding ApplyQuickActionCommand}"
                                        Content="Apply quick action" />
                                <Button Style="{StaticResource SuccessActionButton}"
                                        AutomationProperties.AutomationId="RunSelectedButton"
                                        Command="{Binding RunSelectedCommand}"
                                        Content="Run selected" />
                                <Button Style="{StaticResource SuccessActionButton}"
                                        AutomationProperties.AutomationId="RunAllButton"
                                        Command="{Binding RunAllCommand}"
                                        Content="Run all" />
                                <Button Style="{StaticResource SuccessActionButton}"
                                        AutomationProperties.AutomationId="RerunFailedButton"
                                        Command="{Binding RerunFailedCommand}"
                                        Content="Rerun failed" />
                                <Button Style="{StaticResource SuccessActionButton}"
                                        AutomationProperties.AutomationId="RerunFromStepButton"
                                        Command="{Binding RerunFromStepCommand}"
                                        Content="Rerun from step" />
                                <Button AutomationProperties.AutomationId="OpenSelectedSourceButton"
                                        Command="{Binding OpenSelectedSourceCommand}"
                                        Content="Open file" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource StudioPanelCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource StudioSectionTitleText}" Text="Workspace context" />
                            <TextBlock Margin="0,6,0,14"
                                       Style="{StaticResource StudioMutedText}"
                                       Text="Tune filters, capture policy, and profile selection without losing sight of current status or the latest run." />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StudioEyebrowText}" Text="Explorer filter" />
                                    <TextBox Width="190"
                                             AutomationProperties.AutomationId="ExplorerFilterTextBox"
                                             Text="{Binding ExplorerFilter, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource StudioEyebrowText}" Text="Run filter" />
                                    <TextBox Width="190"
                                             AutomationProperties.AutomationId="RunFilterTextBox"
                                             Text="{Binding RunFilter, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Style="{StaticResource StudioEyebrowText}" Text="Retries" />
                                    <TextBox Width="110"
                                             AutomationProperties.AutomationId="RetryOverrideTextBox"
                                             Text="{Binding RetryCountOverrideText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StudioEyebrowText}" Text="Screenshots" />
                                    <ComboBox Width="160"
                                              AutomationProperties.AutomationId="ScreenshotPolicyComboBox"
                                              ItemsSource="{Binding ScreenshotPolicyOptions}"
                                              SelectedItem="{Binding SelectedScreenshotPolicy}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource StudioEyebrowText}" Text="Quick action" />
                                    <ComboBox Width="240"
                                              AutomationProperties.AutomationId="QuickActionComboBox"
                                              ItemsSource="{Binding QuickActions}"
                                              DisplayMemberPath="Title"
                                              SelectedValue="{Binding SelectedQuickActionId}"
                                              SelectedValuePath="Id" />
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Style="{StaticResource StudioEyebrowText}" Text="Profile" />
                                    <ComboBox Width="180"
                                              AutomationProperties.AutomationId="ProfileComboBox"
                                              ItemsSource="{Binding AvailableProfiles}"
                                              SelectedItem="{Binding SelectedProfile}" />
                                </StackPanel>
                            </Grid>

                            <UniformGrid Margin="0,18,0,0" Columns="3">
                                <Border Style="{StaticResource StudioMetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource StudioEyebrowText}" Text="Project root" />
                                        <TextBlock Margin="0,8,0,0"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ProjectRoot}"
                                                   TextWrapping="Wrap"
                                                   AutomationProperties.AutomationId="ProjectRootText" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StudioMetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource StudioEyebrowText}" Text="Status" />
                                        <TextBlock Margin="0,8,0,0"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding StatusMessage}"
                                                   TextWrapping="Wrap"
                                                   AutomationProperties.AutomationId="StatusMessageText" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StudioMetricCard}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource StudioEyebrowText}" Text="Last run" />
                                        <TextBlock Margin="0,8,0,0"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding LastRunSummary}"
                                                   TextWrapping="Wrap"
                                                   AutomationProperties.AutomationId="LastRunSummaryText" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  Three-column workspace (was Grid.Row="1", now Row="2")        -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="430" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource StudioPanelCard}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource StudioSectionTitleText}" Text="Explorer" />
                            <Border Grid.Column="1" Style="{StaticResource StudioStatusPill}" Margin="8,0,0,0">
                                <TextBlock Style="{StaticResource StudioBadgeText}" Text="{Binding FlowCount, StringFormat=Flows {0}}" />
                            </Border>
                        </Grid>
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource StudioMutedText}"
                                   Text="Search project assets quickly, then keep design, source, and evidence panes aligned with the current selection." />
                    </StackPanel>
                    <TreeView ItemsSource="{Binding ExplorerNodes}"
                              AutomationProperties.AutomationId="ProjectExplorerTree"
                              SelectedItemChanged="ProjectTree_OnSelectedItemChanged" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="10"
                          HorizontalAlignment="Stretch"
                          Background="Transparent" />

            <Border Grid.Column="2" Style="{StaticResource StudioPanelCard}">
                <TabControl AutomationProperties.AutomationId="EditorTabControl"
                            Background="Transparent"
                            BorderBrush="Transparent">
                    <TabItem Header="Overview" AutomationProperties.AutomationId="OverviewTab">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8,14,8,0">
                                <UniformGrid Columns="4" Margin="0,0,0,16">
                                    <Border Style="{StaticResource StudioMetricCard}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource StudioEyebrowText}" Text="Flows" />
                                            <TextBlock Margin="0,8,0,0" FontSize="30" FontWeight="SemiBold" Text="{Binding FlowCount}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StudioMetricCard}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource StudioEyebrowText}" Text="Capabilities" />
                                            <TextBlock Margin="0,8,0,0" FontSize="30" FontWeight="SemiBold" Text="{Binding CapabilityCount}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StudioMetricCard}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource StudioEyebrowText}" Text="Fixtures" />
                                            <TextBlock Margin="0,8,0,0" FontSize="30" FontWeight="SemiBold" Text="{Binding FixtureCount}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StudioMetricCard}" Margin="0">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource StudioEyebrowText}" Text="Recent runs" />
                                            <TextBlock Margin="0,8,0,0" FontSize="30" FontWeight="SemiBold" Text="{Binding RunCount}" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <GroupBox Header="Capability coverage">
                                    <DataGrid ItemsSource="{Binding CapabilityCoverage}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Capability" Binding="{Binding CapabilityName}" Width="2*" />
                                            <DataGridTextColumn Header="Id" Binding="{Binding CapabilityId}" Width="*" />
                                            <DataGridTextColumn Header="Flows" Binding="{Binding FlowCount}" Width="Auto" />
                                            <DataGridTextColumn Header="Latest" Binding="{Binding LatestOutcome}" Width="Auto" />
                                            <DataGridTextColumn Header="Acceptance criteria" Binding="{Binding AcceptanceCriteriaCount}" Width="Auto" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </GroupBox>

                                <GroupBox Header="Selected asset">
                                    <TextBox MinHeight="220"
                                             AcceptsReturn="True"
                                             AutomationProperties.AutomationId="SelectedAssetSummaryTextBox"
                                             FontFamily="Consolas"
                                             IsReadOnly="True"
                                             Text="{Binding SelectedAssetSummary, Mode=OneWay}"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" />
                                </GroupBox>

                                <GroupBox Header="Recent activity">
                                    <ListBox ItemsSource="{Binding RecentActivity}" AutomationProperties.AutomationId="RecentActivityList">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Headline}" />
                                                    <TextBlock Foreground="{DynamicResource StudioMutedForegroundBrush}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </GroupBox>

                                <GroupBox Header="Flake watch">
                                    <DataGrid ItemsSource="{Binding FlakyFlows}" AutomationProperties.AutomationId="FlakyFlowsGrid">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Flow" Binding="{Binding Name}" Width="2*" />
                                            <DataGridTextColumn Header="Score" Binding="{Binding FlakeScore}" Width="Auto" />
                                            <DataGridTextColumn Header="Trend" Binding="{Binding Trend}" Width="*" />
                                            <DataGridTextColumn Header="Retries" Binding="{Binding RetryRecoveries}" Width="Auto" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Designer" AutomationProperties.AutomationId="DesignerTab">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8,14,8,0"
                                        Visibility="{Binding HasSelectedFlow, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border Style="{StaticResource StudioPanelCard}" Margin="0,0,0,14" Background="{DynamicResource StudioSurfaceAltBrush}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource StudioSectionTitleText}" Text="Flow metadata" />
                                        <TextBlock Margin="0,6,0,14"
                                                   Style="{StaticResource StudioMutedText}"
                                                   Text="Keep the designer synchronized with source, capability coverage, and run metadata while you author or refine a flow." />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource StudioEyebrowText}" Text="Flow id" />
                                                <TextBox AutomationProperties.AutomationId="FlowIdTextBox"
                                                         Text="{Binding SelectedFlow.Id, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Margin="0,10,0,0" Style="{StaticResource StudioEyebrowText}" Text="Flow name" />
                                                <TextBox AutomationProperties.AutomationId="FlowNameTextBox"
                                                         Text="{Binding SelectedFlow.Name, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Margin="0,10,0,0" Style="{StaticResource StudioEyebrowText}" Text="Capability" />
                                                <ComboBox AutomationProperties.AutomationId="CapabilityComboBox"
                                                          IsEditable="True"
                                                          ItemsSource="{Binding CapabilityOptions}"
                                                          SelectedItem="{Binding SelectedFlow.CapabilityId, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Margin="0,10,0,0" Style="{StaticResource StudioEyebrowText}" Text="Tags" />
                                                <TextBox AutomationProperties.AutomationId="FlowTagsTextBox"
                                                         Text="{Binding SelectedFlow.TagsText, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Style="{StaticResource StudioEyebrowText}" Text="Status" />
                                                <TextBox AutomationProperties.AutomationId="FlowStatusTextBox"
                                                         Text="{Binding SelectedFlow.Status, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Margin="0,10,0,0" Style="{StaticResource StudioEyebrowText}" Text="Summary" />
                                                <TextBox MinHeight="110"
                                                         AcceptsReturn="True"
                                                         AutomationProperties.AutomationId="FlowSummaryTextBox"
                                                         Text="{Binding SelectedFlow.Summary, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto" />
                                                <TextBlock Margin="0,10,0,0" Style="{StaticResource StudioEyebrowText}" Text="Source file" />
                                                <TextBox AutomationProperties.AutomationId="FlowFilePathTextBox"
                                                         IsReadOnly="True"
                                                         Text="{Binding SelectedFlow.FilePath, Mode=OneWay}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <GroupBox Header="Quick actions and diagnostics">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="240" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ListBox ItemsSource="{Binding QuickActions}"
                                                 AutomationProperties.AutomationId="QuickActionsList"
                                                 DisplayMemberPath="Title"
                                                 SelectedValue="{Binding SelectedQuickActionId}"
                                                 SelectedValuePath="Id" />
                                        <TextBox Grid.Column="2"
                                                 AcceptsReturn="True"
                                                 AutomationProperties.AutomationId="FlowAnalysisSummaryTextBox"
                                                 IsReadOnly="True"
                                                 Text="{Binding FlowAnalysisDetails, Mode=OneWay}"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto" />
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Fixtures">
                                    <DataGrid ItemsSource="{Binding SelectedFlow.Fixtures}"
                                              MinHeight="120"
                                              AutomationProperties.AutomationId="FixturesDataGrid"
                                              CanUserAddRows="True"
                                              CanUserDeleteRows="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Alias" Binding="{Binding Alias, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                            <DataGridTextColumn Header="Use" Binding="{Binding Use, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                            <DataGridTextColumn Header="Source" Binding="{Binding Source, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                            <DataGridTextColumn Header="For" Binding="{Binding For, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </GroupBox>

                                <GroupBox Header="Actions">
                                    <DataGrid ItemsSource="{Binding SelectedFlow.Actions}"
                                              MinHeight="200"
                                              AutomationProperties.AutomationId="ActionsDataGrid"
                                              CanUserAddRows="True"
                                              CanUserDeleteRows="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Step" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                            <DataGridTextColumn Header="Inputs (key=value per line)" Binding="{Binding InputsText, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </GroupBox>

                                <GroupBox Header="Expectations">
                                    <DataGrid ItemsSource="{Binding SelectedFlow.Expectations}"
                                              MinHeight="160"
                                              AutomationProperties.AutomationId="ExpectationsDataGrid"
                                              CanUserAddRows="True"
                                              CanUserDeleteRows="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Expect" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                            <DataGridTextColumn Header="Inputs (key=value per line)" Binding="{Binding InputsText, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Source" AutomationProperties.AutomationId="SourceTab">
                        <Grid Margin="8,14,8,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Margin="0,0,0,12"
                                       Style="{StaticResource StudioMutedText}"
                                       Text="Edit source directly, keep indentation intact, and apply changes back into the designer when you are ready to validate or save." />
                            <TextBox Grid.Row="1"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     AutomationProperties.AutomationId="SourceEditorTextBox"
                                     FontFamily="Consolas"
                                     HorizontalScrollBarVisibility="Auto"
                                     Text="{Binding SourceEditorText, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="10"
                          HorizontalAlignment="Stretch"
                          Background="Transparent" />

            <Border Grid.Column="4" Style="{StaticResource StudioPanelCard}">
                <TabControl AutomationProperties.AutomationId="ResultsTabControl"
                            Background="Transparent"
                            BorderBrush="Transparent">
                    <TabItem Header="Live run" AutomationProperties.AutomationId="LiveRunTab">
                        <Grid Margin="8,14,8,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock AutomationProperties.AutomationId="LiveRunHeadlineText"
                                       FontWeight="SemiBold"
                                       Text="{Binding LiveRunHeadline}" />
                            <ListBox Grid.Row="1"
                                     Margin="0,12,0,0"
                                     AutomationProperties.AutomationId="LiveEventsList"
                                     ItemsSource="{Binding LiveEvents}" />
                        </Grid>
                    </TabItem>

                    <TabItem Header="Runs" AutomationProperties.AutomationId="RunsTab">
                        <Grid Margin="8,14,8,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="2.1*" />
                                <RowDefinition Height="1.4*" />
                                <RowDefinition Height="1.2*" />
                                <RowDefinition Height="1.25*" />
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="1.9*" />
                            </Grid.RowDefinitions>

                            <GroupBox Header="Recent runs">
                                <ListBox ItemsSource="{Binding Runs}"
                                         AutomationProperties.AutomationId="RunsList"
                                         SelectedItem="{Binding SelectedRun}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                                <TextBlock Foreground="{DynamicResource StudioMutedForegroundBrush}" Text="{Binding Summary}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </GroupBox>

                            <GroupBox Grid.Row="1" Header="Flows">
                                <ListBox ItemsSource="{Binding SelectedRunFlows}"
                                         AutomationProperties.AutomationId="RunFlowsList"
                                         SelectedItem="{Binding SelectedRunFlow}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="84" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Outcome}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" TextWrapping="Wrap" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </GroupBox>

                            <GroupBox Grid.Row="2" Header="Steps">
                                <ListBox ItemsSource="{Binding SelectedRunSteps}"
                                         AutomationProperties.AutomationId="RunStepsList"
                                         SelectedItem="{Binding SelectedRunStep}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                <TextBlock Foreground="{DynamicResource StudioMutedForegroundBrush}" Text="{Binding Kind}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </GroupBox>

                            <GroupBox Grid.Row="3" Header="Artifacts and reports">
                                <ListBox ItemsSource="{Binding SelectedRunArtifacts}"
                                         AutomationProperties.AutomationId="ArtifactsList"
                                         SelectedItem="{Binding SelectedArtifact}"
                                         VirtualizingStackPanel.IsVirtualizing="False">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                                <TextBlock Foreground="{DynamicResource StudioMutedForegroundBrush}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </GroupBox>

                            <GroupBox Grid.Row="4" Header="Comparison">
                                <TextBox AcceptsReturn="True"
                                         AutomationProperties.AutomationId="RunComparisonTextBox"
                                         IsReadOnly="True"
                                         Text="{Binding SelectedRunComparison, Mode=OneWay}"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                            </GroupBox>

                            <GroupBox Grid.Row="5" Header="Preview">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Button HorizontalAlignment="Left"
                                            AutomationProperties.AutomationId="OpenSelectedArtifactButton"
                                            Command="{Binding OpenSelectedArtifactCommand}"
                                            Content="Open selected artifact" />
                                    <Grid Grid.Row="1" Margin="0,10,0,0">
                                        <TextBox AcceptsReturn="True"
                                                 AutomationProperties.AutomationId="PreviewTextBox"
                                                 FontFamily="Consolas"
                                                 IsReadOnly="True"
                                                 Text="{Binding PreviewText, Mode=OneWay}"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Visibility="{Binding HasPreviewText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Image AutomationProperties.AutomationId="PreviewImage"
                                               Source="{Binding PreviewImage}"
                                               Stretch="Uniform"
                                               Visibility="{Binding HasPreviewImage, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </Grid>
                                </Grid>
                            </GroupBox>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Diagnostics" AutomationProperties.AutomationId="DiagnosticsTab">
                        <Grid Margin="8,14,8,0">
                            <ListBox ItemsSource="{Binding Diagnostics}" AutomationProperties.AutomationId="DiagnosticsList">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Summary}" />
                                            <TextBlock Foreground="{DynamicResource StudioMutedForegroundBrush}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
